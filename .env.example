# OpenSky now uses OAuth2 client credentials. Leave blank for anonymous access
# (which has a lower daily quota).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Viracopos / Campinas
CENTER_LAT=-23.0074
CENTER_LON=-47.1345
DEFAULT_RADIUS_KM=200
# 300 s respeita a cota do acesso anônimo. Com OAuth2, pode usar 10 s.
POLL_INTERVAL_SECONDS=300
# Frequência de gravação do histórico local; a interface continua atualizando no intervalo acima.
HISTORY_INTERVAL_SECONDS=60
DATABASE_PATH=data/skymon.db
